dict1={1:'Apple',2:'Banana',3:'Cherry'}
dict2={6:'VIJAY',7:'SK',8:'SURYA'}
print("D1= ",dict1)
print("D2= ",dict2)
print("By OR operator")
d3=dict(dict1.items() | dict2.items())
print(d3)
print("Update function")
dict4=dict1.copy()
dict4.update(dict2)
print(dict4)
print("Using dictionary unpacking method")
d5={**dict1, **dict2}
print(d5)
print("Using for loop")
dict6={}
for k, v in dict1.items():
    dict6[k] = v
for k, v in dict2.items():
    dict6[k] = v
print(dict6)
